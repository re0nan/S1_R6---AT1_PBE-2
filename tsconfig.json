{
  "compilerOptions": {
    "target": "ES2023",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2023"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "express", "multer"],
    "outDir": "./dist",
    "rootDir": "./src", 
    "sourceMap": true,
    "ignoreDeprecations": "5.0"
  },
  "include": ["src/**/*"]
}